# Default normalization
* text=auto

# Keep Git control files stable
.gitattributes text eol=lf
.gitignore    text eol=lf

# MATLAB / Octave source
*.m   text eol=crlf
*.mat binary

# General text files
*.md   text=auto
*.tex  text=auto
*.bib  text=auto
*.csv  text=auto
*.tsv  text=auto
*.json text=auto
*.yaml text=auto
*.yml  text=auto
*.xml  text=auto
*.py   text=auto

# Shell scripts must stay LF
*.sh   text eol=lf
*.bash text eol=lf

# Project-specific TXT policy
docs/project_structure/*.txt      text eol=lf
labs/1st/programs/output/*.txt    text eol=crlf
*.txt                             text=auto

# Binary assets
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.zip  binary
*.xlsx binary
*.xls  binary
*.docx binary
*.pptx binary