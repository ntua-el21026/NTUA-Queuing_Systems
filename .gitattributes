# Default behavior
* text=auto

# Keep repository control files as LF to avoid bootstrap/safecrlf issues
.gitattributes text eol=lf
.gitignore    text eol=lf

# MATLAB / Octave
*.m   text eol=crlf
*.mat binary

# Text / docs
*.txt  text=auto
*.md   text=auto
*.tex  text=auto
*.bib  text=auto
*.csv  text=auto
*.tsv  text=auto
*.json text=auto
*.yaml text=auto
*.yml  text=auto
*.xml  text=auto

# Scripts
*.py   text=auto
*.sh   text eol=lf
*.bash text eol=lf

# Binary files
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.zip  binary
*.xlsx binary
*.xls  binary
*.docx binary
*.pptx binary
